{
	"id": "observeclaw",
	"configSchema": {
		"type": "object",
		"additionalProperties": false,
		"properties": {
			"enabled": {
				"type": "boolean",
				"default": true
			},
			"currency": {
				"type": "string",
				"enum": ["USD", "EUR"],
				"default": "USD"
			},
			"routing": {
				"type": "object",
				"properties": {
					"enabled": { "type": "boolean", "default": false },
					"logRouting": { "type": "boolean", "default": true },
					"evaluators": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string" },
								"type": { "type": "string", "enum": ["regex", "classifier", "webhook"] },
								"priority": { "type": "number" },
								"enabled": { "type": "boolean" },
								"patterns": { "type": "array", "items": { "type": "string" } },
								"provider": { "type": "string" },
								"model": { "type": "string" },
								"url": { "type": "string" },
								"classifierModel": { "type": "string" },
								"prompt": { "type": "string" },
								"routes": { "type": "object", "additionalProperties": { "type": "object", "properties": { "provider": { "type": "string" }, "model": { "type": "string" } } } },
								"headers": { "type": "object", "additionalProperties": { "type": "string" } },
								"timeoutMs": { "type": "number" },
								"emitEvent": { "type": "boolean", "default": false },
								"webhooks": { "type": "array", "items": { "type": "string" } },
								"blockMessage": { "type": "boolean", "default": false },
								"blockReply": { "type": "string" }
							},
							"required": ["name", "type", "priority", "enabled"]
						}
					}
				}
			},
			"budgets": {
				"type": "object",
				"properties": {
					"defaults": {
						"type": "object",
						"properties": {
							"daily": { "type": "number", "default": 100 },
							"monthly": { "type": "number", "default": 2000 },
							"warnAt": { "type": "number", "default": 0.8 }
						}
					},
					"agents": {
						"type": "object",
						"additionalProperties": {
							"type": "object",
							"properties": {
								"daily": { "type": "number" },
								"monthly": { "type": "number" },
								"warnAt": { "type": "number" }
							}
						}
					}
				}
			},
			"toolPolicy": {
				"type": "object",
				"properties": {
					"defaults": {
						"type": "object",
						"properties": {
							"allow": { "type": "array", "items": { "type": "string" } },
							"deny": { "type": "array", "items": { "type": "string" } }
						}
					},
					"agents": {
						"type": "object",
						"additionalProperties": {
							"type": "object",
							"properties": {
								"allow": { "type": "array", "items": { "type": "string" } },
								"deny": { "type": "array", "items": { "type": "string" } }
							}
						}
					}
				}
			},
			"anomaly": {
				"type": "object",
				"properties": {
					"spendSpikeMultiplier": { "type": "number", "default": 3 },
					"idleBurnMinutes": { "type": "number", "default": 10 },
					"errorLoopThreshold": { "type": "number", "default": 10 },
					"tokenInflationMultiplier": { "type": "number", "default": 2 },
					"checkIntervalSeconds": { "type": "number", "default": 30 }
				}
			},
			"downgradeModel": { "type": "string", "default": "claude-haiku-4-5" },
			"downgradeProvider": { "type": "string", "default": "anthropic" },
			"pricing": {
				"type": "object",
				"additionalProperties": {
					"type": "object",
					"properties": {
						"input": { "type": "number" },
						"output": { "type": "number" },
						"cacheRead": { "type": "number" },
						"cacheWrite": { "type": "number" }
					}
				}
			},
			"webhooks": {
				"type": "array",
				"items": {
					"type": "object",
					"properties": {
						"url": { "type": "string" },
						"minSeverity": { "type": "string", "enum": ["info", "warning", "critical"] },
						"headers": { "type": "object", "additionalProperties": { "type": "string" } },
						"timeoutMs": { "type": "number" }
					},
					"required": ["url"]
				}
			}
		}
	},
	"uiHints": {
		"enabled": { "label": "Enable ObserveClaw", "help": "Enable agent spend tracking, budget enforcement, and anomaly detection" },
		"currency": { "label": "Currency", "help": "Currency for budget display (cost calculation is always in USD internally)" },
		"budgets.defaults.daily": { "label": "Default Daily Budget", "help": "Default daily spend limit per agent" },
		"budgets.defaults.monthly": { "label": "Default Monthly Budget", "help": "Default monthly spend limit per agent" },
		"downgradeModel": { "label": "Downgrade Model", "help": "Model to force when agent approaches budget limit" }
	}
}
